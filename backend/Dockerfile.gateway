FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY src/FieldTaskManager.Gateway/FieldTaskManager.Gateway.csproj src/FieldTaskManager.Gateway/
RUN dotnet restore src/FieldTaskManager.Gateway/FieldTaskManager.Gateway.csproj

COPY src/ src/
RUN dotnet publish src/FieldTaskManager.Gateway/FieldTaskManager.Gateway.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app/publish .
ENV ASPNETCORE_HTTP_PORTS=8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "FieldTaskManager.Gateway.dll"]
