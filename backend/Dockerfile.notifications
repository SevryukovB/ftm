FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY src/FieldTaskManager.NotificationService/FieldTaskManager.NotificationService.csproj src/FieldTaskManager.NotificationService/
RUN dotnet restore src/FieldTaskManager.NotificationService/FieldTaskManager.NotificationService.csproj

COPY src/ src/
RUN dotnet publish src/FieldTaskManager.NotificationService/FieldTaskManager.NotificationService.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app/publish .
ENV ASPNETCORE_HTTP_PORTS=8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "FieldTaskManager.NotificationService.dll"]
