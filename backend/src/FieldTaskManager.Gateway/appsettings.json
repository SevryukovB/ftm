{
  "ReverseProxy": {
    "Routes": {
      "notifications": {
        "ClusterId": "notifications",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "api": {
        "ClusterId": "api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "api": {
            "Address": "http://localhost:5081"
          }
        }
      },
      "notifications": {
        "Destinations": {
          "notifications": {
            "Address": "http://localhost:5082"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*"
}
